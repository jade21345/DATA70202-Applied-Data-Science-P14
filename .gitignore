# --- Data ---
# Raw vendor data: large binary geopackages and election spreadsheets.
# These files are publicly available from DGT and the AR website; the
# README explains how to download them. They must not enter git
# because individual gpkg files exceed GitHub's 100MB hard limit.
data_raw/
!data_raw/.gitkeep

# Intermediate ETL outputs: regenerated by scripts/01_prepare_data.py
# from data_raw/. There is no value in tracking them.
data_clean/
!data_clean/.gitkeep

# Scratch space for ad-hoc analysis. Never tracked.
intermediate/
!intermediate/.gitkeep

# --- Pipeline outputs are tracked ---
# We DO track outputs/ on git so that Jade (frontend) and reviewers can
# see the deliverables without running the pipeline. The trade-off is
# that re-running the pipeline produces large diffs; the team
# convention is to commit outputs only when promoting a release-quality
# version, not on every local rerun. To temporarily ignore your local
# changes to outputs without untracking them globally, use:
#     git update-index --skip-worktree outputs/scenarios/baseline_2025/...

# --- Internal notes ---
# Chinese-language working notes for the supervisor only; not for the
# public repo.
docs/notes_zh.md

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
.venv/
venv/

# --- IDEs and tooling ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
