# Raw data — too large, document source in README
data_raw/

# Intermediate pipeline products — regenerable
intermediate/

# Clean data — keep small tabular files, exclude large geo files
data_clean/*.gpkg
data_clean/*.shp
data_clean/*.shx
data_clean/*.dbf

# Outputs — keep frontend-ready exports, exclude preview images
outputs/*
!outputs/geojson/
!outputs/tables/
!outputs/json/
!outputs/documentation/
!outputs/.gitkeep

# Keep directory placeholders
!data_raw/.gitkeep
!intermediate/.gitkeep

# Internal notes (Chinese-language working notes)
docs/notes_zh.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/

# IDEs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/